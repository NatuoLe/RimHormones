<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>MuscleStrainHediff</defName>
    <label>肌肉拉伤</label>
    <description>肌肉拉伤会降低肢体效率并造成疼痛。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(1.0, 0.4, 0.2)</defaultLabelColor>
    <isBad>true</isBad>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <painOffset>0.1</painOffset>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.03</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>
</Defs>