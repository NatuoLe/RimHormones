<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>Cortisol</defName>
    <label>cortisol</label>
    <description>Cortisol hormone representing chronic stress accumulation. Severity indicates hormone concentration level. High cortisol causes fatigue, immune suppression, and metabolic changes.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <makesAlert>false</makesAlert>
    <stages>
      <li>
        <label>sleep deprivation</label>
        <minSeverity>0</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
        <statFactors>
          <RestFallRateFactor>1.2</RestFallRateFactor>
        </statFactors>
      </li>
      <li>
        <label>normal</label>
        <minSeverity>0.15</minSeverity>
      </li>
      <li>
        <label>chronic stress</label>
        <minSeverity>0.5</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.03</offset>
          </li>
          <li>
            <capacity>Metabolism</capacity>
            <offset>0.10</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
        <statFactors>
          <InjuryHealingFactor>0.95</InjuryHealingFactor>
          <ImmunityGainSpeedFactor>0.95</ImmunityGainSpeedFactor>
        </statFactors>
        <hungerRateFactorOffset>0.15</hungerRateFactorOffset>
      </li>
      <li>
        <label>overload</label>
        <minSeverity>0.75</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.05</offset>
          </li>
          <li>
            <capacity>Metabolism</capacity>
            <offset>0.15</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
        <statFactors>
          <InjuryHealingFactor>0.97</InjuryHealingFactor>
          <ImmunityGainSpeedFactor>0.90</ImmunityGainSpeedFactor>
        </statFactors>
        <hungerRateFactorOffset>0.30</hungerRateFactorOffset>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>CortisolNeurasthenia</defName>
    <label>neurasthenia</label>
    <description>Nervous exhaustion from prolonged high cortisol levels. Causes insomnia and mood disturbances.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <makesAlert>true</makesAlert>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <statFactors>
          <RestFallRateFactor>1.6</RestFallRateFactor>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>0.40</MentalBreakThreshold>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>CortisolOverloadExhaustion</defName>
    <label>overload exhaustion</label>
    <description>Severe exhaustion from sustained cortisol overload. All bodily functions are significantly impaired.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <makesAlert>true</makesAlert>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <statFactors>
          <WorkSpeedGlobal>0.70</WorkSpeedGlobal>
          <MoveSpeed>0.80</MoveSpeed>
          <RestFallRateFactor>2.0</RestFallRateFactor>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>0.30</MentalBreakThreshold>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.20</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>
