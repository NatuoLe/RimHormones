<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- 皮质醇状态显示用 Hediff（用于在健康面板显示浓度） -->
  <HediffDef>
    <defName>CortisolStatus</defName>
    <label>皮质醇状态</label>
    <description>当前慢性压力水平。显示在健康面板中。</description>
    <hediffClass>Hormones.HediffComp_CortisolStatus</hediffClass>
    <isBad>false</isBad>
    <makesAlert>false</makesAlert>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
      </li>
    </stages>
  </HediffDef>

  <!-- 废弃：皮质醇效果已迁移至 Need_Cortisol -->
  <HediffDef>
    <defName>Cortisol</defName>
    <label>皮质醇（废弃）</label>
    <description>废弃：皮质醇效果已迁移至 Need 系统。当前浓度请查看 Need 界面。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <makesAlert>false</makesAlert>
  </HediffDef>

  <HediffDef>
    <defName>CortisolNeurasthenia</defName>
    <label>神经衰弱</label>
    <description>长期高皮质醇导致的神经耗竭。睡眠效率下降、情绪低落，且可叠加。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <makesAlert>true</makesAlert>
    <defaultLabelColor>(1.0, 0.4, 0.2)</defaultLabelColor>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <statFactors>
          <!-- 休息效率 -13%：乘 RestRateMultiplier（睡眠时休息值回复速度），UI「休息效率乘数」会显示 ×87% -->
          <RestRateMultiplier>0.87</RestRateMultiplier>
        </statFactors>
      </li>
    </stages>
    <comps>
      <!-- 心情惩罚改由 ThoughtWorker_NeurastheniaMood 按体魄分档评估（见 Thought_Neurasthenia.xml），不再用 ThoughtSetter -->
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>180000</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>CortisolOverloadExhaustion</defName>
    <label>过载衰竭</label>
    <description>持续皮质醇过载导致的严重衰竭。所有身体功能都显著受损。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <makesAlert>true</makesAlert>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <statFactors>
          <WorkSpeedGlobal>0.70</WorkSpeedGlobal>
          <MoveSpeed>0.80</MoveSpeed>
          <RestFallRateFactor>2.0</RestFallRateFactor>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>0.30</MentalBreakThreshold>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.20</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>
